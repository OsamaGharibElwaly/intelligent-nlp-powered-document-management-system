GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
# HTTP timeouts & retries (fault tolerance)
GROQ_HTTP_CONNECT_TIMEOUT=10
GROQ_HTTP_READ_TIMEOUT=55
GROQ_MAX_ATTEMPTS=3
GROQ_RETRY_BACKOFF_MS=400
JWT_SECRET=replace_with_a_secure_secret
TOKEN_EXPIRY=60
# Dev-only: promote users via POST /admin/bootstrap/promote (omit or empty to disable).
ADMIN_BOOTSTRAP_SECRET=123abc
STORAGE_PATH=storage
ALLOWED_ORIGINS=https://your-frontend.vercel.app
